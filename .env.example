# Podcast Reels Forge — environment variables
#
# Copy this file to `.env` and fill in only what you need. The default pipeline
# runs fully locally (faster-whisper + llama.cpp) and needs NO API keys.
# `.env` is git-ignored and must never be committed.

# --- Diarization (optional) -------------------------------------------------
# Required ONLY if you enable diarization (subtitles per speaker).
# A Hugging Face access token with access to the pyannote models.
# Get one at https://huggingface.co/settings/tokens and accept the model terms
# at https://huggingface.co/pyannote/speaker-diarization
PYANNOTE_TOKEN=

# --- Cloud LLM providers (optional) -----------------------------------------
# Only needed if you switch the analysis stage away from local llama.cpp to a
# hosted provider in config.yaml. Leave blank for the default local setup.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Advanced (optional) ----------------------------------------------------
# Override the ffmpeg binary used by the pipeline (absolute path).
# FORGE_FFMPEG=/usr/bin/ffmpeg
#
# Set to 1 to enable extra debug logging in the helper scripts.
# DEBUG_FORGE=0
